# Postgres connection string (Supabase → Project Settings → Database → Connection string, "URI")
DATABASE_URL=postgres://user:password@host:5432/postgres

# Telegram (from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_ADMIN_CHAT_ID=

# Groq (console.groq.com → API Keys)
GROQ_API_KEY=

# Vercel Cron shared secret (any random string you generate yourself)
CRON_SECRET=

# Dashboard basic-auth gate
DASHBOARD_USER=brunella
DASHBOARD_PASSWORD=

# Meta (Messenger + Instagram + WhatsApp comparten la misma app de Meta for Developers)
META_APP_SECRET=
META_VERIFY_TOKEN=
MESSENGER_PAGE_ACCESS_TOKEN=
INSTAGRAM_ACCESS_TOKEN=

# WhatsApp Cloud API
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_NUMBER=
# Plantilla aprobada por Meta para el envío masivo de seguimiento (opcional).
# Sin WHATSAPP_TEMPLATE_SEGUIMIENTO, el comando "seguimiento" del bot solo previsualiza.
WHATSAPP_TEMPLATE_SEGUIMIENTO=
WHATSAPP_TEMPLATE_LANG=es_AR

# URL pública de la app deployada (para armar el link del formulario)
APP_BASE_URL=
